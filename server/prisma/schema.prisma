generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           Int      @id @default(autoincrement())
  fullname                     String?
  email                        String   @unique
  password                     String
  refreshToken                 String
  role                         String
  isEmailVerified              Boolean
  emailVerificationToken       String
  emailVerificationTokenExpiry DateTime
}
